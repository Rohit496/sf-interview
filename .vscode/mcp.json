{
    "servers": {
        "apex-log-mcp": {
            "command": "npx",
            "args": [
                "-y",
                "@certinia/apex-log-mcp",
                "--allowed-orgs",
                "DEFAULT_TARGET_ORG"
            ]
        },
        "Salesforce DX": {
            "command": "npx",
            "args": [
                "-y",
                "@salesforce/mcp@latest",
                "--orgs",
                "ALLOW_ALL_ORGS",
                "--toolsets",
                "all"
            ]
        }
    }
}